# Keep the build context lean — none of these belong in the image.
node_modules
.next
.git
.gitignore
.gitattributes
*.md
.env*
!.env.example
Dockerfile
# corepack auto-generates this stub with placeholder text; if present it makes
# pnpm treat the project as a workspace and the build fails ("packages field
# missing or empty"). Exclude it.
pnpm-workspace.yaml
docker-compose*.yml
.DS_Store
.vscode
.idea
coverage
*.log
npm-debug.log*
.pnpm-store

# Owner's raw imagery source folder (~120MB) + misc — originals live in public/
# after the duotone-grade pass. Excluding here keeps the Docker build context lean.
pictures
New folder
scripts/tmp
